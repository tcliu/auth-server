{
  "name": "auth-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "env:sync:vercel": "node ./scripts/sync-vercel-env.mjs",
    "auth:generate": "node ./scripts/generate-auth-schema.mjs",
    "auth:migrate": "node ./scripts/migrate-auth-schema.mjs",
    "auth:build:neon": "node ./scripts/build-neon-schema.mjs"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.11",
    "better-auth": "^1.6.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.15.6",
    "svelte": "^5.55.5",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "8.0.10",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "cookie": "^1.1.1"
  }
}

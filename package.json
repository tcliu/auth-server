{
  "name": "auth-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "auth:generate": "auth generate --config ./src/lib/server/auth.ts --output ./schema.sql --yes",
    "auth:migrate": "auth migrate --config ./src/lib/server/auth.ts --yes"
  },
  "dependencies": {
    "better-auth": "^1.6.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^6.1.0",
    "@sveltejs/kit": "^2.39.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "svelte": "^5.43.5",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  }
}

# Public URL for the auth server itself
BETTER_AUTH_URL=http://localhost:3001

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-real-secret

# Better Auth database
DATABASE_URL=postgres://user:password@localhost:5432/auth_server

# Comma-separated allowed browser and app origins
AUTH_TRUSTED_ORIGINS=http://localhost:5173,capacitor://localhost,ionic://localhost

# JWT audience for downstream consumers
JWT_AUDIENCE=http://localhost:3001

# Optional branding
AUTH_APP_NAME=Auth Server

# Optional mail integration
MAIL_FROM=codeplayground@zohomail.com
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=codeplayground@zohomail.com
SMTP_PASS=

# Optional social login
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# OAuth 2.1 / OIDC trusted client for portfolio-manager
OAUTH_PM_CLIENT_ID=portfolio-manager
# Leave empty for a public PKCE client, or set a secret for a confidential web client
OAUTH_PM_CLIENT_SECRET=
OAUTH_PM_REDIRECT_URIS=http://localhost:5173/auth/callback,https://codepg-portfolio-manager.vercel.app/auth/callback
OAUTH_PM_POST_LOGOUT_REDIRECT_URIS=http://localhost:5173/,https://codepg-portfolio-manager.vercel.app/
OAUTH_PM_AUDIENCE=https://codepg-portfolio-manager.vercel.app

# Dynamic registration is off by default for safety
OAUTH_ALLOW_DYNAMIC_CLIENT_REGISTRATION=false
